<section class="bg-light py-5" id="offres">
    <div class="row row-cols-1 row-cols-md-2 row-cols-lg-4 g-4">

        {% for offer in offers %}
            {# Logique d'affichage : On met en avant l'offre 'Start-up' (bordure et bouton bleu) #}
            {% set isFeatured = (offer.label == 'Start-up') %}
            {% set cardClass = isFeatured ? 'card h-100 shadow-sm border-primary' : 'card h-100 shadow-sm' %}
            {% set headerClass = isFeatured ? 'card-header py-3 text-center text-white bg-primary border-primary' : 'card-header py-3 text-center bg-white' %}
            {% set btnClass = isFeatured ? 'w-100 btn btn-lg btn-primary' : 'w-100 btn btn-lg btn-outline-primary' %}

            <div class="col">
                <div class="{{ cardClass }}">
                    <div class="{{ headerClass }}">
                        <h4 class="my-0 fw-normal">{{ offer.label }}</h4>
                    </div>
                    <div class="card-body d-flex flex-column text-center">
                        <h1 class="card-title pricing-card-title">
                            {{ offer.price|number_format(0, ',', ' ') }} €
                            <small class="text-muted fw-light">/mois</small>
                        </h1>

                        <ul class="list-unstyled mt-3 mb-4 flex-grow-1">
                            <li>
                                <strong>{{ offer.unitsNumber }} Unité{{ offer.unitsNumber > 1 ? 's' : '' }}</strong>
                                {# Ajout des précisions selon le nombre d'unités #}
                                {% if offer.unitsNumber == 42 %} <br><small class="text-muted">(Baie complète)</small>
                                {% elseif offer.unitsNumber == 21 %} <br><small class="text-muted">(Demi-baie)</small>
                                {% endif %}
                            </li>

                            {# Affichage de la réduction si elle existe #}
                            {% if offer.reduction > 0 %}
                                <li class="mt-2"><span class="badge bg-success">-{{ offer.reduction }}% de réduction</span></li>
                            {% else %}
                                {# Espace vide pour garder l'alignement des cartes #}
                                <li class="mt-2">&nbsp;</li>
                            {% endif %}

                            {# Description contextuelle (Optionnel : vous pourriez ajouter un champ 'description' en BDD plus tard) #}
                            <li class="mt-2 fst-italic text-muted">
                                {% if offer.label == 'Base' %}Idéal pour débuter
                                {% elseif offer.label == 'Start-up' %}Pour les équipes agiles
                                {% elseif offer.label == 'PME' %}Infrastructure robuste
                                {% elseif offer.label == 'Entreprise' %}Solution intégrale
                                {% endif %}
                            </li>
                        </ul>

                        {# Lien de commande : On prépare le terrain pour passer l'ID de l'offre #}
                        {# Pour l'instant on garde '#' pour ne pas créer d'erreur #}
                        <a href="{{ path('app_purchase', {'id': offer.id}) }}" class="btn btn-primary">Choisir</a>
                    </div>
                </div>
            </div>
        {% else %}
            <div class="col-12">
                <div class="alert alert-info text-center">
                    Aucune offre commerciale n'est disponible pour le moment.
                </div>
            </div>
        {% endfor %}

    </div>
</section>