{# Gestion des commandes (Locations / Rentals) #}
<div class="card shadow-sm">
    <div class="card-header bg-dark text-white">
        <h5 class="mb-0">Mes Commandes</h5>
    </div>
    <div class="card-body p-0">
        <ul class="list-group list-group-flush">
            {# Boucle sur les locations du client #}
            {% for rental in rentals %}
                <li class="list-group-item d-flex flex-column gap-2 py-3">

                    {# Ligne 1 : Titre et Badge Actif #}
                    <div class="d-flex justify-content-between align-items-center w-100">
                        <span class="fw-bold">Pack {{ rental.offer.label }} ({{ rental.offer.unitsNumber }}U)</span>
                        <span class="badge bg-success rounded-pill">Actif</span>
                    </div>

                    {# Ligne 2 : Statut de l'abonnement et Bouton d'action #}
                    <div class="d-flex justify-content-between align-items-end mt-1">

                        {# Partie gauche : Date et statut #}
                        <div class="text-muted small">
                            Statut : <br>
                            {% if rental.isAutoRenew %}
                                <span class="badge bg-success text-white">Renouvellement le {{ rental.endDate|date('d/m/Y') }}</span>
                            {% else %}
                                <span class="badge bg-warning text-dark">Prend fin le {{ rental.endDate|date('d/m/Y') }}</span>
                            {% endif %}
                        </div>

                        {# Partie droite : Formulaire avec le bouton #}
                        <form action="{{ path('toggle_auto_renew', {'id': rental.id}) }}" method="POST" class="m-0">
                            {% if rental.isAutoRenew %}
                                <button type="submit" class="btn btn-outline-danger btn-sm" onclick="return confirm('Êtes-vous sûr de vouloir annuler le renouvellement automatique ? Vos serveurs seront libérés à la fin de la période.');">
                                    <i class="bi bi-x-circle me-1"></i> Annuler l'abonnement
                                </button>
                            {% else %}
                                <button type="submit" class="btn btn-success btn-sm">
                                    <i class="bi bi-arrow-repeat me-1"></i> Réactiver l'abonnement
                                </button>
                            {% endif %}
                        </form>
                    </div>

                </li>
            {% else %}
                <li class="list-group-item text-muted text-center small py-4">
                    Aucune location en cours.
                </li>
            {% endfor %}
        </ul>
        <div class="p-3">
            <a href="{{ path('app_home') }}#offres" class="btn btn-warning w-100 fw-bold">Nouvelle commande</a>
        </div>
    </div>
</div>
